YOUTUBE_API_KEY=your_youtube_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Models (optional — defaults below are recommended)
# Options: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
# discovery_model = finds top niches from trending data (1 call per run)
# analysis_model  = deep analysis per niche (1 call x number of niches)
DISCOVERY_MODEL=claude-sonnet-4-6
ANALYSIS_MODEL=claude-sonnet-4-6
